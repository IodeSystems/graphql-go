#!/usr/bin/env bash
#
# bin/perf — compare benchmark performance between two git refs.
#
# Uses git worktrees so the working tree is never disturbed. Auto-detects
# query-plan support (presence of plan_bench_test.go) per ref.
#
#   - both refs support plan: A vs B comparison on planned + plan-cache benches
#   - one ref supports plan: 4-tier comparison on the supporting ref
#       (uncached → planned → +append → +append-eager)
#       Frames the case for the non-supporting ref to adopt plan support.
#   - neither: plan section is skipped.
#
# Usage:
#   bin/perf                              # upstream/master vs HEAD
#   bin/perf <ref-a> <ref-b>              # explicit refs
#   bin/perf <ref-a> <ref-b> --no-readme  # skip README update; print to stdout
#
# Environment:
#   PERF_COUNT      benchmark iterations per bench (default: 6)
#   PERF_BENCHTIME  per-iteration time budget (default: 2s)
#
# Requires: go, git, benchstat (auto-installed if missing).

set -euo pipefail

# Single-arg mode: bin/perf <ref> benchmarks the current working tree
# (even if dirty) against <ref>. Two-arg mode: bin/perf <ref-a> <ref-b>
# uses worktrees for both sides (requires clean commits).
UPDATE_README=1
for arg in "$@"; do
    [ "$arg" = "--no-readme" ] && UPDATE_README=0
done
if [ $# -eq 1 ] || { [ $# -eq 2 ] && [ "$2" = "--no-readme" ]; }; then
    REF_A="${1}"
    REF_B="."
elif [ $# -eq 2 ]; then
    REF_A="${1}"
    REF_B="${2}"
else
    REF_A="upstream/master"
    REF_B="HEAD"
fi

PARSE_PATTERN='^BenchmarkParse_'
# When both refs support query plan, compare A vs B on planned + cache benches.
PLAN_AB_PATTERN='^BenchmarkPlanned|^BenchmarkPlanCache_'
# When only one ref supports query plan, the four execution tiers run
# independently and pair by suffix after prefix-stripping.
PLAN_ONLY_UNCACHED='^BenchmarkUncachedExecute_'
PLAN_ONLY_PLANNED='^BenchmarkPlannedExecute_'
PLAN_ONLY_APPEND='^BenchmarkPlannedAppend_'
COUNT="${PERF_COUNT:-6}"
BENCHTIME="${PERF_BENCHTIME:-2s}"

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

err() { echo "perf: $*" >&2; }

# Resolve refs. "." means current working tree (no checkout needed).
USE_DIR_B=0
if [ "$REF_B" = "." ]; then
    SHA_A=$(git rev-parse --verify "$REF_A" 2>/dev/null) || { err "unknown ref: $REF_A"; exit 1; }
    SHORT_A=$(git rev-parse --short "$SHA_A")
    SHORT_B="dirty"
    USE_DIR_B=1
else
    SHA_A=$(git rev-parse --verify "$REF_A" 2>/dev/null) || { err "unknown ref: $REF_A"; exit 1; }
    SHA_B=$(git rev-parse --verify "$REF_B" 2>/dev/null) || { err "unknown ref: $REF_B"; exit 1; }
    SHORT_A=$(git rev-parse --short "$SHA_A")
    SHORT_B=$(git rev-parse --short "$SHA_B")
fi

if ! command -v benchstat >/dev/null; then
    err "installing benchstat..."
    go install golang.org/x/perf/cmd/benchstat@latest
fi
if ! command -v benchstat >/dev/null; then
    err "benchstat not on PATH after install; check \$GOBIN/\$GOPATH/bin"
    exit 1
fi

TMP=$(mktemp -d)
WT_A="$TMP/wt-a"
WT_B="$TMP/wt-b"

cleanup() {
    git worktree remove --force "$WT_A" >/dev/null 2>&1 || true
    git worktree remove --force "$WT_B" >/dev/null 2>&1 || true
    rm -rf "$TMP"
}
trap cleanup EXIT

err "preparing worktrees..."
git worktree add --detach "$WT_A" "$SHA_A" >/dev/null
if [ "$USE_DIR_B" = "0" ]; then
    git worktree add --detach "$WT_B" "$SHA_B" >/dev/null
else
    WT_B="$REPO_ROOT"
fi

has_plan() { test -f "$1/plan_bench_test.go"; }
has_parse_bench() { test -f "$1/language/parser/parser_bench_test.go"; }

PLAN_A=0; has_plan "$WT_A" && PLAN_A=1
PLAN_B=0; has_plan "$WT_B" && PLAN_B=1
PARSE_OK=0
# Both refs need parser_bench_test.go. If either is missing, copy from the
# ref that does have it so we can still measure parse on the other side.
if has_parse_bench "$WT_A" && has_parse_bench "$WT_B"; then
    PARSE_OK=1
elif has_parse_bench "$WT_A" || has_parse_bench "$WT_B"; then
    SRC="$WT_A"
    DST="$WT_B"
    if has_parse_bench "$WT_B"; then SRC="$WT_B"; DST="$WT_A"; fi
    # Rewrite module import path so the file compiles on the destination.
    SRC_MOD=$(head -1 "$SRC/go.mod" | awk '{print $2}')
    DST_MOD=$(head -1 "$DST/go.mod" | awk '{print $2}')
    if [ "$SRC_MOD" != "$DST_MOD" ]; then
        sed "s|$SRC_MOD|$DST_MOD|g" "$SRC/language/parser/parser_bench_test.go" \
            > "$DST/language/parser/parser_bench_test.go"
    else
        cp "$SRC/language/parser/parser_bench_test.go" "$DST/language/parser/parser_bench_test.go"
    fi
    PARSE_OK=1
    err "copied parser_bench_test.go from $SRC into $DST (module: $SRC_MOD -> $DST_MOD)"
fi

# normalize_pkg rewrites the "pkg:" line in a benchmark output file to a
# module-agnostic form so benchstat can pair results across forks with
# different module paths. E.g.:
#   pkg: github.com/IodeSystems/graphql-go/language/parser
# becomes:
#   pkg: language/parser
normalize_pkg() {
    sed -i -E 's|^pkg: .*/([^/]+)$|pkg: \1|' "$1"
}

run_bench() {
    local dir=$1 pat=$2 pkg=$3 out=$4
    err "  $pat ($pkg) in $(basename "$dir")"
    (cd "$dir" && go test -run='^$' -bench="$pat" -benchtime="$BENCHTIME" -count="$COUNT" "$pkg" 2>/dev/null) > "$out"
}

# File names show up as benchstat column headers — keep them short and meaningful.
PARSE_OUT_A="$TMP/${SHORT_A}-parse.txt"
PARSE_OUT_B="$TMP/${SHORT_B}-parse.txt"
PLAN_OUT_A="$TMP/${SHORT_A}-plan.txt"
PLAN_OUT_B="$TMP/${SHORT_B}-plan.txt"
# Solo path: per-tier files (uncached/planned/append) on each supporting ref.
PLAN_SOLO_UNCACHED_A="$TMP/${SHORT_A}-uncached.txt"
PLAN_SOLO_PLANNED_A="$TMP/${SHORT_A}-planned.txt"
PLAN_SOLO_APPEND_A="$TMP/${SHORT_A}-append.txt"
PLAN_SOLO_UNCACHED_B="$TMP/${SHORT_B}-uncached.txt"
PLAN_SOLO_PLANNED_B="$TMP/${SHORT_B}-planned.txt"
PLAN_SOLO_APPEND_B="$TMP/${SHORT_B}-append.txt"

if [ "$PARSE_OK" = "1" ]; then
    err "==> parse benchmarks ($SHORT_A)"
    run_bench "$WT_A" "$PARSE_PATTERN" "./language/parser/" "$PARSE_OUT_A"
    err "==> parse benchmarks ($SHORT_B)"
    run_bench "$WT_B" "$PARSE_PATTERN" "./language/parser/" "$PARSE_OUT_B"
    # Normalize pkg: lines so benchstat can pair across module paths.
    normalize_pkg "$PARSE_OUT_A"
    normalize_pkg "$PARSE_OUT_B"
fi

# Strip the variant prefix so a per-tier benchstat run pairs benchmarks
# by their shared suffix.
strip_plan_prefix() {
    sed -i \
        -e 's/PlannedAppend_/Execute_/g' \
        -e 's/PlannedExecute_/Execute_/g' \
        -e 's/UncachedExecute_/Execute_/g' \
        "$1"
}

run_solo_tiers() {
    local short=$1 wt=$2
    local uncached=$3 planned=$4 append=$5
    err "==> per-tier benchmarks ($short) — solo (other ref lacks plan)"
    run_bench "$wt" "$PLAN_ONLY_UNCACHED"     "./" "$uncached"
    run_bench "$wt" "$PLAN_ONLY_PLANNED"      "./" "$planned"
    run_bench "$wt" "$PLAN_ONLY_APPEND"       "./" "$append"
    strip_plan_prefix "$uncached"
    strip_plan_prefix "$planned"
    strip_plan_prefix "$append"
}

if [ "$PLAN_A" = "1" ] && [ "$PLAN_B" = "1" ]; then
    err "==> plan benchmarks ($SHORT_A)"
    run_bench "$WT_A" "$PLAN_AB_PATTERN" "./" "$PLAN_OUT_A"
    err "==> plan benchmarks ($SHORT_B)"
    run_bench "$WT_B" "$PLAN_AB_PATTERN" "./" "$PLAN_OUT_B"
    # Normalize pkg: lines so benchstat can pair across module paths.
    normalize_pkg "$PLAN_OUT_A"
    normalize_pkg "$PLAN_OUT_B"
elif [ "$PLAN_A" = "1" ]; then
    run_solo_tiers "$SHORT_A" "$WT_A" \
        "$PLAN_SOLO_UNCACHED_A" "$PLAN_SOLO_PLANNED_A" \
        "$PLAN_SOLO_APPEND_A"
elif [ "$PLAN_B" = "1" ]; then
    run_solo_tiers "$SHORT_B" "$WT_B" \
        "$PLAN_SOLO_UNCACHED_B" "$PLAN_SOLO_PLANNED_B" \
        "$PLAN_SOLO_APPEND_B"
fi

# summary_table renders an N-column markdown table from benchstat's CSV
# output. Args: title label1 file1 label2 file2 [label3 file3 ...].
# Cells after the first column include the inline "vs base" delta.
summary_table() {
    local title=$1
    shift
    local labels=() files=()
    while [ $# -ge 2 ]; do
        labels+=("$1")
        files+=("$2")
        shift 2
    done
    local n=${#files[@]}
    local dir
    dir=$(dirname "${files[0]}")
    local basenames=()
    local f
    for f in "${files[@]}"; do basenames+=("$(basename "$f")"); done

    (cd "$dir" && benchstat -format csv "${basenames[@]}" 2>/dev/null) | \
    awk -v title="$title" -v labels_str="${labels[*]}" '
        BEGIN { FS=","; n_labels = split(labels_str, lbl, " ") }
        function fmt(s,    v) {
            v = s + 0
            if (v == 0) return s
            if (v < 1e-6) return sprintf("%.0fns", v*1e9)
            if (v < 1e-3) return sprintf("%.2fµs", v*1e6)
            if (v < 1)    return sprintf("%.2fms", v*1000)
            return sprintf("%.2fs", v)
        }
        # Render base/val as a multiplier. >1x = faster than base, <1x = slower.
        function fmt_mult(m) {
            if (m >= 100) return sprintf("%.0fx", m)
            if (m >= 10)  return sprintf("%.1fx", m)
            return sprintf("%.2fx", m)
        }
        $2 == "sec/op" { in_section = 1; next }
        $2 == "B/op" || $2 == "allocs/op" { in_section = 0; next }
        /^,/ { next }
        in_section && $1 != "" {
            is_geo = ($1 == "geomean")
            if (!printed) {
                print "**" title " — sec/op (× = base/val; >1× faster)**"
                print ""
                row = "| Benchmark"
                sep = "|---"
                for (i = 1; i <= n_labels; i++) {
                    row = row " | " lbl[i]
                    sep = sep "|---:"
                }
                print row " |"
                print sep "|"
                printed = 1
            }
            row = is_geo ? "| **" $1 "**" : "| " $1
            base_val = $2 + 0
            for (i = 1; i <= n_labels; i++) {
                if (i == 1) {
                    cell = (base_val == 0) ? fmt($2) : fmt($2) " (1.00x)"
                } else {
                    # CSV layout per added file: val, ci, vs base, P
                    # Field offsets: val_i = 4*i - 4, delta_i = 4*i - 2
                    vfield = 4 * i - 4
                    dfield = 4 * i - 2
                    delta = $dfield
                    val = $vfield + 0
                    if (val == 0 || base_val == 0) {
                        # No measurement, or no base to compare to.
                        cell = fmt($vfield)
                    } else if (delta == "" || delta == "~") {
                        cell = fmt($vfield) " (~)"
                    } else {
                        cell = fmt($vfield) " (" fmt_mult(base_val / val) ")"
                    }
                }
                if (is_geo) cell = "**" cell "**"
                row = row " | " cell
            }
            print row " |"
        }
    '
}

# emit_section: same arg shape as summary_table, plus a leading hint string.
# Args: title hint label1 file1 label2 file2 ...
emit_section() {
    local title=$1 hint=$2
    shift 2
    local labels=() files=()
    while [ $# -ge 2 ]; do
        labels+=("$1")
        files+=("$2")
        shift 2
    done
    local f
    for f in "${files[@]}"; do
        if [ ! -s "$f" ]; then
            printf "**%s**\n\n_Not run: %s_\n\n" "$title" "$hint"
            return
        fi
    done
    local args=()
    local i
    for ((i=0; i<${#labels[@]}; i++)); do
        args+=("${labels[$i]}" "${files[$i]}")
    done
    summary_table "$title" "${args[@]}"
    local dir
    dir=$(dirname "${files[0]}")
    local basenames=()
    for f in "${files[@]}"; do basenames+=("$(basename "$f")"); done
    printf "\n<details>\n<summary>Full benchstat output</summary>\n\n\`\`\`\n"
    (cd "$dir" && benchstat "${basenames[@]}" 2>/dev/null)
    printf "\`\`\`\n\n</details>\n\n"
}

DATE=$(date -u +%Y-%m-%d)
TABLE=$(mktemp)
{
    printf "_Generated by \`bin/perf\` on %s. A=\`%s\` (%s), B=\`%s\` (%s). count=%s, benchtime=%s._\n\n" \
        "$DATE" "$REF_A" "$SHORT_A" "$REF_B" "$SHORT_B" "$COUNT" "$BENCHTIME"

    if [ "$PARSE_OK" = "1" ]; then
        emit_section "Parser" "no parse benchmarks in either ref" \
            "$SHORT_A" "$PARSE_OUT_A" \
            "$SHORT_B" "$PARSE_OUT_B"
    else
        printf "**Parser**\n\n_Not run: no parser_bench_test.go in either ref._\n\n"
    fi

    if [ "$PLAN_A" = "1" ] && [ "$PLAN_B" = "1" ]; then
        emit_section "Query plan / execute" "see below" \
            "$SHORT_A" "$PLAN_OUT_A" \
            "$SHORT_B" "$PLAN_OUT_B"
    elif [ "$PLAN_A" = "1" ] || [ "$PLAN_B" = "1" ]; then
        if [ "$PLAN_A" = "1" ]; then
            SOLO_REF="$REF_A"; SOLO_SHORT="$SHORT_A"
            UNCACHED="$PLAN_SOLO_UNCACHED_A"
            PLANNED="$PLAN_SOLO_PLANNED_A"
            APPEND="$PLAN_SOLO_APPEND_A"
            OTHER_LABEL="B"
        else
            SOLO_REF="$REF_B"; SOLO_SHORT="$SHORT_B"
            UNCACHED="$PLAN_SOLO_UNCACHED_B"
            PLANNED="$PLAN_SOLO_PLANNED_B"
            APPEND="$PLAN_SOLO_APPEND_B"
            OTHER_LABEL="A"
        fi
        printf "**Query plan / execute**\n\n"
        printf "_Only \`%s\` has \`plan_bench_test.go\`. The table below stacks three execution tiers on the supporting ref. \`uncached\` is the baseline (no plan caching, default executor). \`planned\` adds plan caching (default-on for adopters; the case for %s to merge plan support). \`+append\` adopts the resolver-side append API (opt-in, requires schema-author changes). Δ on each tier is vs the \`uncached\` baseline._\n\n" \
            "$SOLO_REF" "$OTHER_LABEL"
        emit_section "Execution tiers on $SOLO_SHORT" "missing per-tier output" \
            "uncached"     "$UNCACHED" \
            "planned"      "$PLANNED" \
            "+append"      "$APPEND"
    else
        printf "**Query plan / execute**\n\n_Not run: neither ref has \`plan_bench_test.go\`._\n\n"
    fi
} > "$TABLE"

if [ "$UPDATE_README" = "0" ]; then
    cat "$TABLE"
    exit 0
fi

README="$REPO_ROOT/README.md"
if [ ! -f "$README" ]; then
    err "README.md not found; printing to stdout"
    cat "$TABLE"
    exit 0
fi

START="<!-- perf-start -->"
END="<!-- perf-end -->"

if grep -q "$START" "$README" && grep -q "$END" "$README"; then
    awk -v start="$START" -v end="$END" -v table_file="$TABLE" '
        BEGIN { in_section = 0 }
        index($0, start) { print; while ((getline line < table_file) > 0) print line; in_section = 1; next }
        index($0, end)   { in_section = 0; print; next }
        !in_section { print }
    ' "$README" > "$README.tmp"
    mv "$README.tmp" "$README"
    err "updated README.md between markers"
else
    err "no perf markers in README.md; please add a Performance section with:"
    err "  $START"
    err "  $END"
    err "or run bin/perf <a> <b> --no-readme to print to stdout"
    exit 1
fi
